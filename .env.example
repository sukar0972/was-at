# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/visittracker
# Set to 'true' when connecting to an external Postgres over TLS (e.g., managed DB)
# DATABASE_SSL=false

# Security
JWT_SECRET=change-this-to-a-random-string-at-least-32-chars

# CORS (optional; set to your frontend origin, e.g., https://your-domain.com)
# CORS_ORIGIN=https://your-domain.com

# Server
PORT=3000
NODE_ENV=production
